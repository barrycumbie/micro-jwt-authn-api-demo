# ──────────────────────────────────────────────────────────────────────────────
# DEMO AUTHENTICATION SERVICE — ENVIRONMENT VARIABLES
#
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# To regenerate the password hash for a new demo password run:
#   npm run hash-password
# ──────────────────────────────────────────────────────────────────────────────

# bcrypt hash of the demo password ("cat").
# Generate a new one with: npm run hash-password
AUTHN_PASSWORD_HASH=$2b$12$kI7lYDXR.WzPDTrRPgGM1uA6IqpwY0LSzYvbb7Cba24uUgMBn5SCu

# Secret used to sign JWTs. Change this to a long random string in any real deployment.
JWT_SECRET=change-me-to-a-long-random-secret

# How long issued tokens are valid (uses the ms / jsonwebtoken duration format).
JWT_EXPIRES_IN=1h

# Port the service listens on.
PORT=3000

# Rate limiting for POST /api/authn/login (optional — defaults shown below)
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
# RATE_LIMIT_MAX=20             # max requests per window per IP
